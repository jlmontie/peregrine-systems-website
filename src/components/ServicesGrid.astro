---
import Brandmark from "./Brandmark.astro";

interface Service {
  title: string;
  description: string;
  bullets: string[];
  href: string;
}

interface Props {
  services?: Service[];
}

const defaultServices: Service[] = [
  {
    title: "Implementation",
    description: "Build Salesforce correctly from the start — from initial architecture to go-live — without interrupting day-to-day operations.",
    bullets: ["Org design & data model", "AgentForce + CPQ specialties", "Migration, integrations, go-live"],
    href: "/services#implementation",
  },
  {
    title: "Optimization",
    description: "Untangle a Salesforce org that has grown messy. Simplify workflows, reduce technical debt, and rebuild processes your team will actually use.",
    bullets: ["Org Health Audit", "Technical debt remediation", "Architecture refactor"],
    href: "/services#optimization",
  },
  {
    title: "Managed Services",
    description: "Ongoing support, releases, and operational improvements without building an internal Salesforce team.",
    bullets: ["Backlog triage & releases", "User support, training, AgentForce tuning", "Quarterly roadmap"],
    href: "/services#managed",
  },
  {
    title: "System Mapping",
    description: "Make the org legible. One visual map of the business process with the underlying automation overlaid — so every decision lands on something everyone can see. This gives leadership, operations, and technical teams a shared understanding of how the business actually runs inside Salesforce.",
    bullets: ["End-to-end process map", "Automation overlay", "Living source of truth"],
    href: "/system-mapping",
  },
];

const { services = defaultServices } = Astro.props;
---

<section class="section">
  <div class="mx-auto w-full max-w-6xl px-5 sm:px-8">
    <div class="grid gap-10 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] md:items-end">
      <div>
        <span class="eyebrow">What we do</span>
        <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl">Salesforce built to match the business.</h2>
        <span class="rule-divider mt-6"></span>
      </div>
      <p class="text-base leading-relaxed text-[color:var(--color-ink-muted)] md:max-w-prose">
        We work with Salesforce teams from small to enterprise — fresh orgs, inherited orgs, and orgs that have stopped working the way the business does. Four shapes the work takes: build, fix, run, and map. One outcome: a CRM your team actually uses.
      </p>
    </div>

    <div class="mt-12 grid gap-px overflow-hidden rounded border border-[color:var(--color-rule)] bg-[color:var(--color-rule)] sm:grid-cols-2">
      {
        services.map((s) => (
          <a
            href={s.href}
            class="group relative bg-[color:var(--color-cream)] p-8 transition-colors hover:bg-[color:var(--color-cream-2)]"
          >
            <div class="flex items-start justify-between gap-4">
              <h3 class="text-2xl">{s.title}</h3>
              <Brandmark decorative class="h-[18px] w-auto shrink-0 opacity-70 transition-transform group-hover:scale-105" />
            </div>
            <p class="mt-4 text-sm leading-relaxed text-[color:var(--color-ink-muted)]">{s.description}</p>
            <ul class="mt-5 space-y-1.5 text-sm text-[color:var(--color-ink-2)]">
              {s.bullets.map((b) => (
                <li class="flex items-start gap-2">
                  <span aria-hidden="true" class="mt-2 inline-block h-px w-3 bg-[color:var(--color-gold)]" />
                  <span>{b}</span>
                </li>
              ))}
            </ul>
            <span class="mt-6 inline-flex items-center gap-2 text-xs font-medium uppercase tracking-[0.18em] text-[color:var(--color-gold)]">
              Learn more <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
