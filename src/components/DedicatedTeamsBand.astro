---
const bullets = [
  "No more rotating teams.",
  "No more “I’m busy with another client.”",
  "No more “they don’t work for us.”",
  "No more “that person who knew that was moved to another client.”",
];
---

<section class="section">
  <div class="mx-auto w-full max-w-6xl px-5 sm:px-8">
    <div class="grid gap-10 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] md:items-end">
      <div>
        <span class="eyebrow">How we staff</span>
        <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl">A team built for you, by you, and not shared.</h2>
        <span class="rule-divider mt-6"></span>
      </div>
      <p class="text-base leading-relaxed text-[color:var(--color-ink-muted)] md:max-w-prose">
        Big firms limit their team to people in their network and share them across accounts. We don't. We work with you to build your custom, dedicated, dream team — even if we have to acquire them.
      </p>
    </div>

    <ul class="mt-12 grid gap-px overflow-hidden rounded border border-[color:var(--color-rule)] bg-[color:var(--color-rule)] sm:grid-cols-2">
      {
        bullets.map((b, i) => (
          <li class="flex items-start gap-4 bg-[color:var(--color-cream)] p-8">
            <span class="font-[Michroma,sans-serif] text-xs tracking-[0.3em] text-[color:var(--color-gold)]">
              0{i + 1}
            </span>
            <span class="text-base leading-relaxed text-[color:var(--color-ink-2)]">{b}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
