---
const paths = [
  {
    title: "Built for you",
    body: "We assemble the team around your org — CPQ, AgentForce, integrations, admin, architecture. Senior consultants, the certifications to back it, and no filler seats. You meet them before the engagement starts.",
  },
  {
    title: "Built around the team you trust",
    body: "Stuck in a contract you've outgrown, but the developers know your org cold? Bring them with you. We'll onboard your existing team to our roster and run the engagement at a price that reflects the work, not the markup.",
  },
];
---

<section class="section">
  <div class="mx-auto w-full max-w-6xl px-5 sm:px-8">
    <div class="grid gap-10 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] md:items-end">
      <div>
        <span class="eyebrow">How we staff</span>
        <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl">A team built for your org. Yours, not shared.</h2>
        <span class="rule-divider mt-6"></span>
      </div>
      <p class="text-base leading-relaxed text-[color:var(--color-ink-muted)] md:max-w-prose">
        Big firms rotate consultants across accounts. We don't. Every engagement gets a dedicated team — sized to your stack, named on day one, and accountable to your roadmap. No rotating bench, no handoffs mid-project, no "the person who knew that left last quarter."
      </p>
    </div>

    <div class="mt-12 grid gap-px overflow-hidden rounded border border-[color:var(--color-rule)] bg-[color:var(--color-rule)] sm:grid-cols-2">
      {
        paths.map((p, i) => (
          <article class="bg-[color:var(--color-cream)] p-8">
            <span class="font-[Michroma,sans-serif] text-xs tracking-[0.3em] text-[color:var(--color-gold)]">
              0{i + 1}
            </span>
            <h3 class="mt-3 text-2xl">{p.title}</h3>
            <p class="mt-4 text-sm leading-relaxed text-[color:var(--color-ink-2)]">{p.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
