---
interface Props {
  width?: number;
  height?: number;
  class?: string;
  alt?: string;
  loading?: "eager" | "lazy";
  decorative?: boolean;
}

const {
  width,
  height,
  class: className = "",
  alt = "Peregrine Systems",
  loading = "eager",
  decorative = false,
} = Astro.props;
---

<img
  src="/logo.svg"
  width={width}
  height={height}
  class={className}
  alt={decorative ? "" : alt}
  aria-hidden={decorative ? "true" : undefined}
  loading={loading}
  decoding="async"
/>
