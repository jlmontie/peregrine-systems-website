---
const principles = [
  {
    title: "Senior consultants. With your users.",
    body: "You work directly with the senior consultant — and they work directly with your users. No layered staffing, no junior account team between us and the people using the system.",
  },
  {
    title: "Configure before you code.",
    body: "We exhaust declarative tools before reaching for Apex. Your future admin will thank us.",
  },
  {
    title: "Outcomes over hours.",
    body: "We scope to the result you need. You see exactly what you're getting and what it costs before we start.",
  },
];
---

<section class="section">
  <div class="mx-auto w-full max-w-6xl px-5 sm:px-8">
    <div class="text-center">
      <span class="eyebrow">How we operate</span>
      <h2 class="mt-4 text-3xl sm:text-4xl">Three principles, applied to every engagement.</h2>
      <span class="rule-divider rule-divider-center mt-6"></span>
    </div>

    <div class="mt-14 grid gap-10 md:grid-cols-3">
      {
        principles.map((p, i) => (
          <article class="relative pl-6 border-l border-[color:var(--color-gold)]/60">
            <div class="font-[Michroma,sans-serif] text-xs tracking-[0.3em] text-[color:var(--color-gold)]">
              0{i + 1}
            </div>
            <h3 class="mt-3 text-xl leading-snug">{p.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-[color:var(--color-ink-muted)]">{p.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
