---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
}
const { eyebrow, title, lede } = Astro.props;
---

<section class="relative overflow-hidden border-b border-[color:var(--color-rule)]">
  <div class="bg-constellation absolute inset-0 opacity-40 pointer-events-none"></div>
  <div class="relative mx-auto w-full max-w-6xl px-5 sm:px-8 py-20 sm:py-24">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h1 class="mt-6 font-[Michroma,sans-serif] text-4xl sm:text-5xl lg:text-6xl leading-[1.05] tracking-tight max-w-4xl">
      {title}
    </h1>
    {lede && (
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-[color:var(--color-ink-muted)]">
        {lede}
      </p>
    )}
    <span class="rule-divider mt-8"></span>
  </div>
</section>
