---
import Button from "./Button.astro";
import Brandmark from "./Brandmark.astro";

// Decorative motif behind the brandmark. Swap candidates by changing this string:
//   "/chevrons.svg"   — sparse, varied ">" field; reads as forward motion
//   "/slipstream.svg" — hairline streaks with slight downward tilt; reads as wind/stoop
//   "/ridges.svg"     — original mountain silhouette (legacy)
const motifSrc = "/slipstream.svg";
---

<section class="relative overflow-hidden">
  <div class="bg-constellation absolute inset-0 opacity-50 pointer-events-none"></div>

  <div class="relative mx-auto w-full max-w-7xl px-5 sm:px-8 pt-20 pb-24 sm:pt-28 sm:pb-32 lg:pt-32 lg:pb-40">
    <div class="grid items-center gap-12 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <div>
        <span class="eyebrow">Salesforce consulting · est. 2024</span>

        <h1 class="mt-6 font-[Fraunces,serif] text-4xl sm:text-5xl lg:text-6xl xl:text-7xl leading-[1.05] tracking-tight">
          Salesforce that <em class="italic font-normal text-[color:var(--color-gold)]">earns its keep.</em>
        </h1>

        <span class="rule-divider mt-8"></span>

        <p class="mt-8 max-w-xl text-lg leading-relaxed text-[color:var(--color-ink-muted)]">
          We help Salesforce teams from small to enterprise stand up, untangle, and run their org — so the CRM does the work, your people stop fighting it, and the data you trust drives the next decision.
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-4">
          <Button href="/contact" variant="primary">Schedule a consultation</Button>
          <Button href="/services" variant="gold">See how we work</Button>
        </div>

        <dl class="mt-14 grid grid-cols-3 gap-6 max-w-lg">
          <div>
            <!-- TODO: Replace with real founding year / years of experience -->
            <dt class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)]">Years in CRM</dt>
            <dd class="mt-1 font-[Fraunces,serif] text-3xl">10+</dd>
          </div>
          <div>
            <!-- TODO: Replace with real number of certifications across team -->
            <dt class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)]">Certifications</dt>
            <dd class="mt-1 font-[Fraunces,serif] text-3xl">6+</dd>
          </div>
          <div>
            <!-- TODO: Replace with real number of completed orgs / projects -->
            <dt class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)]">Orgs delivered</dt>
            <dd class="mt-1 font-[Fraunces,serif] text-3xl">--</dd>
          </div>
        </dl>
      </div>

      <div class="relative hidden lg:block">
        <div
          class="relative flex min-h-[min(72vh,560px)] w-full items-center justify-center overflow-hidden bg-[color:var(--color-cream)]"
        >
          <div
            class="pointer-events-none absolute inset-0 z-0 bg-[radial-gradient(ellipse_65%_55%_at_50%_40%,rgba(240,229,196,0.55)_0%,rgba(251,250,245,0)_65%)]"
            aria-hidden="true"
          />
          <img
            src={motifSrc}
            alt=""
            width={1200}
            height={240}
            class="pointer-events-none absolute inset-x-[-8%] bottom-0 z-[1] h-[80%] min-h-[140px] w-[116%] max-w-none select-none object-cover object-bottom opacity-[0.99]"
            aria-hidden="true"
            loading="eager"
            decoding="async"
          />
          <div class="relative z-10 mx-auto flex w-full max-w-lg items-center justify-center px-6 py-16">
            <Brandmark decorative class="w-full max-w-[min(100%,420px)] h-auto sm:max-w-[480px]" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
