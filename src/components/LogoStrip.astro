---
// Names-in-prose treatment per BUILDOUT Phase D. Written permission for client logo
// artwork is not in hand; named-team mentions are the legally-clean alternative.
// TODO: Confirm this list with client (open input #5) and add additional names.
const teams = ["GitHub", "Komatsu", "Splunk"];
---

<div class="border-y border-[color:var(--color-rule)] bg-[color:var(--color-cream-2)]">
  <div class="mx-auto w-full max-w-5xl px-5 sm:px-8 py-10 text-center">
    <p class="text-xs uppercase tracking-[0.22em] text-[color:var(--color-ink-muted)]">
      Where our team has built
    </p>
    <p class="mt-5 font-[Michroma,sans-serif] text-xl sm:text-2xl text-[color:var(--color-ink)]">
      {
        teams.map((name, i) => (
          <>
            <span class="whitespace-nowrap">{name}</span>
            {i < teams.length - 1 && <span class="mx-2 text-[color:var(--color-gold)]">·</span>}
          </>
        ))
      }
      <span class="ml-2 text-[color:var(--color-ink-muted)]/70 italic text-base">and others.</span>
    </p>

    <dl class="mt-8 flex flex-wrap items-center justify-center gap-x-12 gap-y-4">
      <div class="text-center">
        {/* TODO: Replace with real founding year / years of experience */}
        <dt class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)]">Years in CRM</dt>
        <dd class="mt-1 font-[Michroma,sans-serif] text-2xl text-[color:var(--color-ink)]">10+</dd>
      </div>
      <div class="text-center">
        {/* TODO: Replace with real number of certifications across team */}
        <dt class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)]">Certifications</dt>
        <dd class="mt-1 font-[Michroma,sans-serif] text-2xl text-[color:var(--color-ink)]">40+</dd>
      </div>
    </dl>
  </div>
</div>
