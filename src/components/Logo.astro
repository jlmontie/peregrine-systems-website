---
import Brandmark from "./Brandmark.astro";
interface Props {
  href?: string;
  size?: "sm" | "md";
}
const { href = "/", size = "md" } = Astro.props;
const markClass = size === "sm" ? "h-[26px] w-auto shrink-0" : "h-9 w-auto shrink-0";
const wordClass =
  size === "sm"
    ? "text-[0.85rem]"
    : "text-[0.95rem] sm:text-[1.05rem]";
---

<a href={href} class="inline-flex items-center gap-3 group" aria-label="Peregrine Systems — home">
  <Brandmark decorative class={markClass} />
  <span
    class={`font-[Michroma,sans-serif] ${wordClass} tracking-[0.02em] text-[color:var(--color-ink)] leading-none`}
  >
    <span>Peregrine</span> <span class="text-[color:var(--color-gold)]"><i>Systems</i></span>
  </span>
</a>
