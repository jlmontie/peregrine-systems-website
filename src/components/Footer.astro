---
import Logo from "./Logo.astro";
const year = new Date().getFullYear();
---

<footer class="mt-12 border-t border-[color:var(--color-rule)] bg-[color:var(--color-cream-2)]">
  <div class="mx-auto w-full max-w-7xl px-5 sm:px-8 py-14">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <Logo />
        <p class="mt-4 max-w-sm text-sm text-[color:var(--color-ink-muted)]">
          Salesforce implementation, optimization, and managed services for teams from small to enterprise.
        </p>
      </div>

      <nav aria-label="Services">
        <h4 class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--color-ink)]">Services</h4>
        <ul class="space-y-2 text-sm text-[color:var(--color-ink-muted)]">
          <li><a class="link-underline" href="/services#implementation">Implementation</a></li>
          <li><a class="link-underline" href="/services#optimization">Optimization</a></li>
          <li><a class="link-underline" href="/services#managed">Managed Services</a></li>
        </ul>
      </nav>

      <nav aria-label="Company">
        <h4 class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--color-ink)]">Company</h4>
        <ul class="space-y-2 text-sm text-[color:var(--color-ink-muted)]">
          <li><a class="link-underline" href="/about">About</a></li>
          <li><a class="link-underline" href="/industries">Industries</a></li>
          <li><a class="link-underline" href="/contact">Contact</a></li>
        </ul>
      </nav>

      <div>
        <h4 class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--color-ink)]">Get in touch</h4>
        <ul class="space-y-2 text-sm text-[color:var(--color-ink-muted)]">
          <li>
            <a class="link-underline" href="mailto:team@northstriderconsulting.com">team@northstriderconsulting.com</a>
          </li>
          <li>
            <a class="link-underline" href="/contact">Schedule a consultation</a>
          </li>
          <!-- TODO: LinkedIn / AppExchange / Trailblazer profile links -->
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-[color:var(--color-rule)] pt-6 text-xs text-[color:var(--color-ink-muted)] sm:flex-row sm:items-center">
      <p>&copy; {year} Peregrine Systems. All rights reserved.</p>
      <p>
        Salesforce, Sales Cloud, Service Cloud, and related marks are trademarks of Salesforce, Inc. Peregrine Systems is an independent firm.
      </p>
    </div>
  </div>
</footer>
