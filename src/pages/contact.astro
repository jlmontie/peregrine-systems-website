---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<BaseLayout
  title="Contact — Peregrine Systems"
  description="Tell us about your Salesforce org, your goals, and what's in the way. We'll come back with a candid read."
>
  <PageHeader
    eyebrow="Contact"
    title="Tell us where you're trying to go."
    lede="The more you can share — current org age, team size, what's working and what isn't — the better the first conversation."
  />

  <section class="section">
    <div class="mx-auto w-full max-w-5xl px-5 sm:px-8 grid gap-14 md:grid-cols-[1.3fr_1fr]">
      <div>
        <div id="form-status" aria-live="polite"></div>
        <form id="contact-form" action="/api/contact" method="post" class="space-y-5">
          {/* Honeypot — hidden from humans, filled by bots. */}
          <div aria-hidden="true" style="position:absolute; left:-9999px; width:1px; height:1px; overflow:hidden;">
            <label>
              Website
              <input type="text" name="website" tabindex="-1" autocomplete="off" />
            </label>
          </div>
          <div class="grid gap-5 sm:grid-cols-2">
            <label class="block">
              <span class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)]">Your name</span>
              <input
                type="text"
                name="name"
                required
                class="mt-2 w-full border border-[color:var(--color-rule)] bg-[color:var(--color-cream)] px-4 py-3 text-[color:var(--color-ink)] focus:border-[color:var(--color-gold)] focus:outline-none"
              />
            </label>
            <label class="block">
              <span class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)]">Email</span>
              <input
                type="email"
                name="email"
                required
                class="mt-2 w-full border border-[color:var(--color-rule)] bg-[color:var(--color-cream)] px-4 py-3 text-[color:var(--color-ink)] focus:border-[color:var(--color-gold)] focus:outline-none"
              />
            </label>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <label class="block">
              <span class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)]">Company</span>
              <input
                type="text"
                name="company"
                class="mt-2 w-full border border-[color:var(--color-rule)] bg-[color:var(--color-cream)] px-4 py-3 text-[color:var(--color-ink)] focus:border-[color:var(--color-gold)] focus:outline-none"
              />
            </label>
            <label class="block">
              <span class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)]">Role</span>
              <input
                type="text"
                name="role"
                placeholder="RevOps, IT, COO, founder…"
                class="mt-2 w-full border border-[color:var(--color-rule)] bg-[color:var(--color-cream)] px-4 py-3 text-[color:var(--color-ink)] focus:border-[color:var(--color-gold)] focus:outline-none"
              />
            </label>
          </div>

          <fieldset>
            <legend class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)]">What kind of help?</legend>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              {
                [
                  "New Salesforce implementation",
                  "Optimize an existing org",
                  "Ongoing admin support",
                  "Training & enablement",
                  "Not sure yet",
                ].map((opt) => (
                  <label class="flex items-center gap-2 text-sm text-[color:var(--color-ink-2)]">
                    <input
                      type="checkbox"
                      name="interest"
                      value={opt}
                      class="h-4 w-4 accent-[color:var(--color-gold)]"
                    />
                    {opt}
                  </label>
                ))
              }
            </div>
          </fieldset>

          <label class="block">
            <span class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)]">Tell us a bit more</span>
            <textarea
              name="message"
              rows="6"
              required
              class="mt-2 w-full border border-[color:var(--color-rule)] bg-[color:var(--color-cream)] px-4 py-3 text-[color:var(--color-ink)] focus:border-[color:var(--color-gold)] focus:outline-none"
            ></textarea>
          </label>

          <button type="submit" class="btn btn-primary">
            Send message
            <span aria-hidden="true">→</span>
          </button>
        </form>
      </div>

      <aside class="space-y-8">
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--color-ink)]">Direct</h2>
          <p class="mt-3 text-sm text-[color:var(--color-ink-muted)]">
            <a class="link-underline text-[color:var(--color-ink-2)]" href="mailto:team@peregrinesys.com">
              team@peregrinesys.com
            </a>
          </p>
        </div>

        <div>
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--color-ink)]">Calendar</h2>
          {/* TODO: Replace with embedded Cal.com / Calendly widget once scheduler is set up. */}
          <p class="mt-3 text-sm text-[color:var(--color-ink-muted)]">
            Prefer to skip the form? <a class="link-underline text-[color:var(--color-ink-2)]" href="#">Book a 30-minute consultation →</a>
          </p>
        </div>

        <div>
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--color-ink)]">What happens next</h2>
          <ol class="mt-3 space-y-2 text-sm text-[color:var(--color-ink-muted)] list-decimal pl-5">
            <li>We reply within one business day.</li>
            <li>30-minute discovery call — no pitch deck.</li>
            <li>If we're a fit, you get a written engagement plan with scope, timeline, and price.</li>
          </ol>
        </div>
      </aside>
    </div>
  </section>

  <script is:inline>
    (function () {
      try {
        const params = new URLSearchParams(window.location.search);
        const status = params.get("contact_status");
        const container = document.getElementById("form-status");
        if (!container || !status) return;

        const messageDiv = document.createElement("div");
        messageDiv.className = "mb-6 rounded border px-4 py-3 text-sm";
        if (status === "success") {
          messageDiv.style.cssText =
            "border-color: rgba(46, 122, 56, 0.3); background: rgba(46, 122, 56, 0.08); color: #2E7A38;";
          messageDiv.innerHTML = "✓ Thanks — your message is on its way. We will respond shortly.";
        } else {
          messageDiv.style.cssText =
            "border-color: rgba(166, 50, 50, 0.3); background: rgba(166, 50, 50, 0.08); color: #A63232;";
          messageDiv.innerHTML =
            'Sorry — there was an error sending your message. Please email <a class="underline" href="mailto:team@peregrinesys.com">team@peregrinesys.com</a>.';
        }
        container.appendChild(messageDiv);

        if (history && history.replaceState) {
          const url = new URL(window.location);
          url.searchParams.delete("contact_status");
          history.replaceState({}, document.title, url.pathname + url.hash);
        }
      } catch (e) {}
    })();
  </script>
</BaseLayout>
